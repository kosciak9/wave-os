{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": [
    "./plugin/notify/index.js",
    [
      "@plannotator/opencode@0.23.1",
      {
        "workflow": "plan-agent",
        "planningAgents": ["brainstorm-planner"],
      },
    ],
    "opencode-worktrunk-workspaces@0.1.0",
    "@alergeek-ventures/opencode@1.2.0",
    "@slkiser/opencode-quota@3.11.2",
    "@gotgenes/opencode-agent-identity@3.1.1",
    "cc-safety-net@1.0.6",
  ],
  "tools": {
    "quota_status": false,
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "exec npx -y @playwright/mcp@0.0.78 --executable-path=\"$(command -v chromium)\"",
      ],
      "enabled": true,
    },
    "context7": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "if CONTEXT7_API_KEY=$(pass show context7.com/api-key 2>/dev/null); then export CONTEXT7_API_KEY; else unset CONTEXT7_API_KEY; fi; exec npx -y @upstash/context7-mcp@3.2.4",
      ],
      "enabled": true,
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
    },
  },
  "permission": {
    "bash": {
      "*": "ask",

      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git grep *": "allow",

      "gh search *": "allow",
      "gh repo view *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",

      "npm view *": "allow",
      "npm info *": "allow",
      "npm search *": "allow",
    },
    "edit": "deny",
    "readGuideline": "deny",
    "listGuidelines": "deny",
    "linear_*": "deny",
  },
  "agent": {
    "brainstorm-planner": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "xhigh",
      "permission": {},
    },
    "build-orchiestrator": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "xhigh",
      "permission": {},
    },
    "plain-coder": {
      "model": "openai/gpt-5.6-terra-fast",
      "permission": {
        "edit": "allow",
      },
    },
    "builder": {
      "model": "openai/gpt-5.6-luna-fast",
      "permission": {
        "edit": "allow",
      },
    },
    "explorer": {
      "model": "openai/gpt-5.6-luna-fast",
      "permission": {},
    },
    "manual-tester": {
      "model": "openai/gpt-5.6-luna-fast",
      "permission": {
        "context7_*": "deny",
      },
    },
    "linear": {
      "model": "openai/gpt-5.6-luna-fast",
      "permission": {
        "linear_*": "allow",
      },
    },
    "code-review-orchestrator": {
      "model": "openai/gpt-5.6-sol-fast",
      "permission": {
        "readGuideline": "allow",
        "listGuidelines": "allow",
      },
    },
    "file-level-code-reviewer": {
      "model": "openai/gpt-5.6-terra-fast",
      "permission": {
        "readGuideline": "allow",
        "listGuidelines": "allow",
      },
    },
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "explore": {
      "disable": true,
    },
  },
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llamacpp",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
      },
      "models": {
        "gemma-4-26b": {
          "name": "Gemma 4 26B MoE",
          "family": "gemma4",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content",
          },
          "limit": {
            "context": 131072,
            "output": 4096,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
  },
}
