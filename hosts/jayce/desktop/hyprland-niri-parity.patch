+std::vector<PHLWORKSPACE> CCompositor::getWorkspacesOnMonitor(PHLMONITOR monitor) const {
+    std::vector<PHLWORKSPACE> result;
+
+    for (const auto& ref : m_workspaces) {
+        const auto workspace = ref.lock();
+        if (valid(workspace) && !workspace->m_isSpecialWorkspace && workspace->m_monitor == monitor)
+            result.emplace_back(workspace);
+    }
+
+    return result;
+}
+
+std::optional<size_t> CCompositor::getWorkspaceOrderIndex(PHLWORKSPACE workspace) const {
+    if (!valid(workspace) || workspace->m_isSpecialWorkspace)
+        return std::nullopt;
+
+    const auto monitor = workspace->m_monitor.lock();
+    if (!monitor)
+        return std::nullopt;
+
+    const auto ordered = getWorkspacesOnMonitor(monitor);
+    const auto it      = std::ranges::find(ordered, workspace);
+    if (it == ordered.end())
+        return std::nullopt;
+
+    return std::distance(ordered.begin(), it);
+}
+
+PHLWORKSPACE CCompositor::getWorkspaceInOrder(PHLWORKSPACE workspace, int64_t offset) const {
+    const auto index = getWorkspaceOrderIndex(workspace);
+    if (!index)
+        return nullptr;
+
+    const auto ordered = getWorkspacesOnMonitor(workspace->m_monitor.lock());
+    const auto target  = sc<int64_t>(*index) + offset;
+    if (target < 0 || target >= sc<int64_t>(ordered.size()))
+        return nullptr;
+
+    return ordered[target];
+}
+
+bool CCompositor::reorderWorkspace(PHLWORKSPACE workspace, int direction) {
+    if (!valid(workspace) || workspace->m_isSpecialWorkspace || direction == 0)
+        return false;
+
+    const auto adjacent = getWorkspaceInOrder(workspace, direction < 0 ? -1 : 1);
+    if (!adjacent)
+        return false;
+
+    const auto workspaceIt = std::ranges::find_if(m_workspaces, [&](const auto& ref) { return ref.lock() == workspace; });
+    const auto adjacentIt  = std::ranges::find_if(m_workspaces, [&](const auto& ref) { return ref.lock() == adjacent; });
+    if (workspaceIt == m_workspaces.end() || adjacentIt == m_workspaces.end())
+        return false;
+
+    std::iter_swap(workspaceIt, adjacentIt);
+    workspace->m_events.orderChanged.emit();
+    adjacent->m_events.orderChanged.emit();
+    g_pEventManager->postEvent(SHyprIPCEvent{"workspaceorder", workspace->m_monitor->m_name});
+    return true;
+}
